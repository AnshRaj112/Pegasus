# Copy to ``Pegasus/.env`` or ``pegasus-backend/.env`` (both are loaded if present;
# ``pegasus-backend/.env`` wins on duplicate keys). Values here override Python defaults.
# If uploads still fail with 52428800 (50 MiB), search your shell and both .env files for
# PEGASUS_VALIDATION_MAX_UPLOAD_BYTES, update it, restart uvicorn, and ensure no export pins the old value.

# Application
PEGASUS_APP_NAME=Pegasus
PEGASUS_ENVIRONMENT=development
PEGASUS_DEBUG=false
PEGASUS_API_V1_PREFIX=/api/v1

# Server (optional overrides for local runs)
PEGASUS_HOST=0.0.0.0
PEGASUS_PORT=8000

# Database (async SQLAlchemy + asyncpg)
# Option A — discrete vars (recommended for shared Postgres / custom schema):
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_HOST=10.0.0.1
# DB_PORT=5432
# DB_NAME=postgres
# DB_SCHEMA=Pegasus
# Option B — full URL in .env (via pydantic Settings) or export in shell:
# PEGASUS_DATABASE_URL=postgresql+asyncpg://pegasus:pegasus@localhost:5432/pegasus
# Shell export of PEGASUS_DATABASE_URL overrides DB_*; DB_* overrides a commented template URL.
# Generate a Fernet key with: python ../scripts/generate_db_encryption_key.py
# PEGASUS_DATABASE_ENCRYPTION_KEY=

# CORS — comma-separated browser origins. When empty and PEGASUS_ENVIRONMENT=development,
# defaults to http://localhost:5173 and http://127.0.0.1:5173 (Vite). Set explicitly for production.
PEGASUS_CORS_ORIGINS=

# POST /api/v1/validate — upload limits and response shaping (per file; default 100 GiB)
PEGASUS_VALIDATION_MAX_UPLOAD_BYTES=107374182400
PEGASUS_VALIDATION_MISMATCH_SAMPLE_LIMIT=0
# Persist runs, mappings, mismatch rows, and durations to PostgreSQL (requires alembic upgrade head).
# Required for the UI History tab (GET /api/v1/validate/history).
PEGASUS_ENABLE_VALIDATION_PERSISTENCE=true

# Parallel validation job queue (startup defaults; override at runtime via PATCH /api/v1/validate/queue)
# PEGASUS_VALIDATION_MAX_CONCURRENCY=2
# PEGASUS_VALIDATION_AUTO_TUNE_ENABLED=true
# PEGASUS_VALIDATION_QUEUE_RAM_MULTIPLIER=4.0
# PEGASUS_VALIDATION_QUEUE_RAM_RESERVE_BYTES=1073741824
# PEGASUS_VALIDATION_QUEUE_MIN_RAM_PER_JOB_BYTES=104857600
# PEGASUS_VALIDATION_QUEUE_MIN_DISK_PER_JOB_BYTES=52428800
# PEGASUS_VALIDATION_QUEUE_DISK_RESERVE_BYTES=524288000
# PEGASUS_VALIDATION_QUEUE_THREADS_PER_JOB=0
# PEGASUS_VALIDATION_QUEUE_DISK_HEADROOM_MULTIPLIER=
# PEGASUS_VALIDATION_RECONCILIATION_DISK_HEADROOM_MULTIPLIER=1.5

# POST /api/v1/validate/local — server-disk CSV paths (no upload). Requires allow flag.
# PEGASUS_VALIDATION_ALLOW_LOCAL_PATHS=false
# Default folder for GET /validate/local/browse when path is omitted (optional).
# PEGASUS_VALIDATION_LOCAL_PATH_DEFAULT_BROWSE=/home/you
# Docker only — use when a host directory is mounted at a *different* path in the container:
# PEGASUS_VALIDATION_LOCAL_PATH_HOST_PREFIX=/home/you/Pegasus/test-data
# PEGASUS_VALIDATION_LOCAL_PATH_CONTAINER_PREFIX=/data/pegasus
# PEGASUS_VALIDATION_LOCAL_PATH_ROOTS=/data/pegasus_csv,/bulk
# PEGASUS_VALIDATION_VALUE_MISMATCH_COLUMN_STATS_MAX_ROWS=250000
