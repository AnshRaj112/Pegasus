# Pegasus backend — used by Docker Compose (env_file) and copied to pegasus-backend/.env for local uvicorn.

PEGASUS_APP_NAME=Pegasus
PEGASUS_ENVIRONMENT=development
PEGASUS_DEBUG=false
PEGASUS_API_V1_PREFIX=/api/v1
PEGASUS_HOST=0.0.0.0
PEGASUS_PORT=8000
PEGASUS_CORS_ORIGINS=

PEGASUS_VALIDATION_MAX_UPLOAD_BYTES=107374182400
PEGASUS_VALIDATION_MISMATCH_SAMPLE_LIMIT=0
PEGASUS_ENABLE_VALIDATION_PERSISTENCE=true
PEGASUS_DATABASE_ENCRYPTION_KEY=C2ekVBDjwmu07axqqykzQ9PtkOTYONInsMTp1-zddmI=
PEGASUS_VALIDATION_RECONCILIATION_DISK_HEADROOM_MULTIPLIER=1.5
PEGASUS_VALIDATION_ALLOW_LOCAL_PATHS=true

# Local file picker: same paths in the UI as on your machine (no Docker remap).
PEGASUS_VALIDATION_LOCAL_PATH_DEFAULT_BROWSE=/home/ansh.raj/Pegasus/test-data

DB_USER=postgres
DB_PASSWORD=teradata
DB_HOST=10.200.104.98
DB_PORT=5432
DB_NAME=postgres
DB_SCHEMA=Pegasus
