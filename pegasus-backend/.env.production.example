# Copy to .env and adjust for a production-like run (frontend on 5173, API on 8000).
# Example: `cp .env.production.example .env` then start uvicorn on port 8000.

PEGASUS_APP_NAME=Pegasus
PEGASUS_ENVIRONMENT=production
PEGASUS_DEBUG=false
PEGASUS_API_V1_PREFIX=/api/v1

PEGASUS_HOST=0.0.0.0
PEGASUS_PORT=8000

PEGASUS_DATABASE_URL=postgresql+asyncpg://pegasus:pegasus@localhost:5432/pegasus
# Generate a Fernet key with: python ../scripts/generate_db_encryption_key.py
# PEGASUS_DATABASE_ENCRYPTION_KEY=

# Browser page origins allowed to call this API (comma-separated). localhost and 127.0.0.1 differ — include both if needed.
PEGASUS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Per CSV file on POST /validate (default 100 GiB; lower in strict environments)
PEGASUS_VALIDATION_MAX_UPLOAD_BYTES=107374182400
PEGASUS_VALIDATION_MISMATCH_SAMPLE_LIMIT=100
PEGASUS_ENABLE_VALIDATION_PERSISTENCE=false
PEGASUS_VALIDATION_RECONCILIATION_DISK_HEADROOM_MULTIPLIER=1.5
PEGASUS_VALIDATION_RECONCILIATION_TEMP_DIR=/tmp/pegasus-recon
PEGASUS_VALIDATION_ALLOW_LOCAL_PATHS=true
PEGASUS_VALIDATION_LOCAL_PATH_ROOTS=/home/ansh.raj/Pegasus/test-data/generated-100m
