# Dev: Vite proxies /api -> http://127.0.0.1:8000 (vite.config.js).
# Leave VITE_API_BASE unset or empty → fetch uses same-origin /api/... (no CORS setup).
# Set VITE_API_BASE=http://127.0.0.1:8000 → browser calls the API host directly (backend CORS must allow http://localhost:5173).
# VITE_API_BASE=http://127.0.0.1:8000
# Optional: client-side poll timeout in ms for long validation jobs (0 = no timeout).
# VITE_VALIDATION_POLL_TIMEOUT_MS=0
